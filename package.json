{
  "name": "@stead/pi-tools",
  "version": "0.1.0",
  "description": "Context-quality and workflow extensions for Pi: model prompts, context-file control, worktrees, file-link footnotes, notifications, stash prompts, context health, and structured compaction",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edhor1608/pi-tools.git"
  },
  "homepage": "https://github.com/edhor1608/pi-tools#readme",
  "bugs": {
    "url": "https://github.com/edhor1608/pi-tools/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "stead",
    "context",
    "context-files",
    "compaction",
    "system-prompt",
    "workflow",
    "stash",
    "notification",
    "terminal-title",
    "file-links",
    "footnotes",
    "rendering",
    "worktree",
    "worktrees"
  ],
  "files": [
    "extensions",
    "defaults",
    "scripts",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "echo 'Test with: pi --no-extensions -e /absolute/path/to/pi-tools'",
    "analyze": "bun ./scripts/analyze-session.ts",
    "test:stash-release": "bun ./scripts/test-stash-release.ts",
    "test:context-files": "bun ./scripts/test-context-files.ts",
    "test:file-footnotes": "bun ./scripts/test-file-footnotes.ts",
    "test:worktrees-intent": "bun ./scripts/test-worktrees-intent.ts",
    "test:worktrees-ensure": "bun ./scripts/test-worktrees-ensure.ts",
    "test:worktrees-cleanup": "bun ./scripts/test-worktrees-cleanup.ts",
    "test:worktrees-extension": "bun ./scripts/test-worktrees-extension.ts",
    "test:packaged-defaults-fallback": "bun ./scripts/test-packaged-defaults-fallback.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/model-system-prompt.ts",
      "./extensions/context-health.ts",
      "./extensions/context-files.ts",
      "./extensions/file-footnotes.ts",
      "./extensions/worktrees.ts",
      "./extensions/notify.ts",
      "./extensions/stash.ts",
      "./extensions/structured-compaction/index.ts"
    ]
  }
}
