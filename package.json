{
  "name": "@stead/pi-tools",
  "version": "0.1.0",
  "description": "Model-specific system prompts and structured compaction for Pi",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edhor1608/pi-tools.git"
  },
  "homepage": "https://github.com/edhor1608/pi-tools#readme",
  "bugs": {
    "url": "https://github.com/edhor1608/pi-tools/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "stead",
    "context",
    "compaction",
    "system-prompt"
  ],
  "files": [
    "extensions",
    "defaults",
    "scripts",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "echo 'Test with: pi --no-extensions -e /absolute/path/to/pi-tools'",
    "analyze": "bun ./scripts/analyze-session.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/model-system-prompt.ts",
      "./extensions/context-health.ts",
      "./extensions/structured-compaction/index.ts"
    ]
  }
}
